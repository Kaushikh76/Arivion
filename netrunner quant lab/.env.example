POSTGRES_USER=duality
POSTGRES_PASSWORD=duality
POSTGRES_DB=duality
DATABASE_URL=postgres://duality:duality@postgres:5432/duality
REDIS_URL=redis://redis:6379
API_PORT=4000
WORKER_PORT=7000
WEB_PORT=3000
QUANT_WORKER_URL=http://worker:7000
DUALITY_VERIFIER_URL=http://verifier:7200
SANDBOX_RUNNER_URL=http://sandbox-runner:7300

# Bybit reference/benchmark market data (preserved — canonical CEX feed)
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_WS_PUBLIC_LINEAR=wss://stream.bybit.com/v5/public/linear
BYBIT_WS_PUBLIC_SPOT=wss://stream.bybit.com/v5/public/spot
EXECUTION_FIDELITY=bar_based
ENABLE_PUBLIC_TRADES=false
L2_DEPTH=50
ENABLE_LATENCY_MODEL=false
DEFAULT_FEED_LATENCY_MS=0
DEFAULT_ORDER_LATENCY_MS=0
DEFAULT_CANCEL_LATENCY_MS=0
SESSION_RECORDING_GRACE_SECONDS=60

# --- Chains / RPC (testnet execution + real Arbitrum DEX market data) ---
# Arbitrum One (chain 42161): real DEX market data ONLY — never execution.
ARBITRUM_ONE_RPC_URL=
ARBITRUM_ONE_WS_URL=
# Arbitrum Sepolia (chain 421614): primary testnet execution chain. Public RPC has no WS support.
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_SEPOLIA_WS_URL=
# Robinhood Chain Testnet (chain 46630): stock-token test/demo chain (ETH gas).
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
ROBINHOOD_TESTNET_WS_URL=wss://feed.testnet.chain.robinhood.com
ROBINHOOD_TESTNET_ALCHEMY_RPC_URL=
ROBINHOOD_TESTNET_ALCHEMY_WS_URL=

# --- Feature flags (DEX data lane + testnet action gating) ---
DUALITY_ENABLE_DEX_DATA=true
DUALITY_ENABLE_TESTNET_ACTIONS=false
DUALITY_ENABLE_RH_TESTNET=true
DUALITY_ENABLE_REAL_TRADER=false
DUALITY_DEX_DEFAULT_DATA_CHAIN_ID=42161
DUALITY_DEFAULT_TEST_EXEC_CHAIN_ID=421614

# --- Optional external DEX market-data APIs ---
GECKOTERMINAL_API_BASE=https://api.geckoterminal.com/api/v2
BITQUERY_API_KEY=
THEGRAPH_API_KEY=

# --- Dune Analytics (on-chain data brain; read-only, allowlisted query pack) ---
# Absent key ⇒ the dune_query tool returns an honest "not configured" panel (no fabricated data).
DUNE_API_KEY=
DUNE_CACHE_TTL_SECONDS=900
DUNE_EXEC_TIMEOUT_SECONDS=55
DUNE_POLL_INTERVAL_MS=1500
DUNE_MAX_ROWS=200
# Map each allowlisted query name to a concrete Dune query id (per-workspace). Unset ⇒ that query is
# reported as unavailable rather than run. Names: uni_pool_overview, uni_pool_history, uni_token_pools,
# gmx_market_stats, gmx_glv_breakdown, gmx_funding_history, token_holder_flow, arb_gas_stats.
DUNE_QUERY_UNI_POOL_OVERVIEW=
DUNE_QUERY_UNI_POOL_HISTORY=
DUNE_QUERY_UNI_TOKEN_POOLS=
DUNE_QUERY_GMX_MARKET_STATS=
DUNE_QUERY_GMX_GLV_BREAKDOWN=
DUNE_QUERY_GMX_FUNDING_HISTORY=
DUNE_QUERY_TOKEN_HOLDER_FLOW=
DUNE_QUERY_ARB_GAS_STATS=

# --- Auth (Privy) ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=
OPENAI_API=
