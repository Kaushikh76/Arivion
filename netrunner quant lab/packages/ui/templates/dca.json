{
  "id": "dca",
  "name": "DCA Accumulator",
  "eligibility": "HISTORICAL_FACTOR_OK",
  "description": "Layered fixed-interval accumulation with drawdown guard.",
  "strategy": {
    "strategy": {
      "name": "DCA Accumulator",
      "universe": { "category": "linear", "symbols": ["BTCUSDT"], "timeframe": "15", "timezone": "UTC" },
      "data_requirements": {
        "candles": "REQUIRED",
        "mark_price": "REQUIRED",
        "funding_rates": "NOT_USED",
        "open_interest": "NOT_USED",
        "orderbook_depth": "NOT_USED"
      },
      "features": { "candle": { "ema_fast": { "type": "ema", "source": "close", "length": 20 } } },
      "entry": { "long_when": { "all": ["close < ema_fast"] } },
      "exit": { "any": ["max_holding_bars:96", "take_profit:0.03", "stop_loss:0.02"] },
      "sizing": { "type": "percent_equity", "max_position_fraction": 0.05 },
      "risk": { "max_leverage": 1, "max_daily_loss_fraction": 0.03, "max_drawdown_kill_fraction": 0.12 },
      "accounting": { "perp_funding": "funding_history_timestamp_driven" }
    }
  }
}
